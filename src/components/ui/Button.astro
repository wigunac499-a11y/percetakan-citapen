---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  className?: string;
}

const { href, variant = 'primary', size = 'md', className = '' } = Astro.props;

const variants = {
  primary: 'bg-accent text-white border-accent hover:bg-accent-light',
  secondary: 'bg-warm text-white border-warm hover:bg-warm-light',
  outline: 'border-accent text-accent hover:bg-accent hover:text-white',
  ghost: 'border-transparent text-accent hover:text-ink hover:bg-muted-light',
};

const sizes = {
  sm: 'px-3 py-1.5 text-xs',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3 text-base',
};
---

{
  href ? (
    <a
      href={href}
      class={`inline-flex items-center justify-center gap-2 rounded-sm border font-medium no-underline transition-all duration-200 ${variants[variant]} ${sizes[size]} ${className}`}
    >
      <slot />
    </a>
  ) : (
    <button
      class={`inline-flex items-center justify-center gap-2 rounded-sm border font-medium transition-all duration-200 ${variants[variant]} ${sizes[size]} ${className}`}
    >
      <slot />
    </button>
  )
}
