---
interface Props {
  tag?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { tag, title, description, align = 'center' } = Astro.props;
---

<div class={`max-w-2xl ${align === 'center' ? 'mx-auto text-center' : ''}`}>
  {tag && (
    <span class="inline-block font-sans text-xs font-semibold uppercase tracking-widest text-accent mb-4 px-0">
      — {tag}
    </span>
  )}
  <h2 class="text-3xl md:text-4xl lg:text-5xl text-ink text-balance" set:html={title} />
  {description && (
    <p class="mt-4 text-ink-light text-base md:text-lg leading-relaxed text-pretty font-sans">
      {description}
    </p>
  )}
</div>
