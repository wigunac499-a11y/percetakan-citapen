---
import SectionHeading from '../ui/SectionHeading.astro';

const seeds = ['undangan-preview-1', 'foto-preview-1', 'undangan-preview-2'];
const categories = ['Undangan', 'Cetak Foto', 'Undangan'];
const titles = ['Undangan Pernikahan Rina & Andi', 'Album Foto Keluarga', 'Undangan Akad Sarah'];
---

<section class="section-padding border-b border-border">
  <div class="container-custom">
    <SectionHeading
      tag="Portofolio"
      title="Hasil Karya Terbaru"
      description="Setiap cetakan adalah karya — lihat langsung hasil kerja kami dari pelanggan yang sudah mempercayakan momen spesialnya."
    />

    <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {seeds.map((seed, i) => {
        const delay = `anim-delay-${i + 1}`;
        return (
        <div key={seed} data-anim="anim-slide-up" class={`${delay} group relative rounded-xl overflow-hidden border border-border bg-white card-shadow`}>
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src={`https://picsum.photos/seed/${seed}/600/750`}
              alt={titles[i]}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-4">
            <span class="text-xs font-semibold uppercase tracking-wider text-accent">{categories[i]}</span>
            <h3 class="text-base font-bold text-ink mt-0.5">{titles[i]}</h3>
          </div>
        </div>
        );
      })}
    </div>

    <div class="mt-12 text-center">
      <a href="/portofolio" class="btn-outline">
        Lihat Semua Portofolio
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
