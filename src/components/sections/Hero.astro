---
---

<section class="relative overflow-hidden bg-gradient-to-br from-accent/5 via-white to-accent/5">
  <div class="container-custom relative py-20 md:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="max-w-xl">
        <span class="badge mb-4">Percetakan Bandung Barat</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight text-balance text-ink">
          Cetak Undangan & Foto
          <span class="block text-accent mt-1">Kualitas Terbaik</span>
        </h1>
        <p class="mt-5 text-lg text-ink-light max-w-lg leading-relaxed text-pretty">
          Dari undangan pernikahan impian hingga cetak foto kenangan berharga —
          kami hadirkan hasil cetak dengan sentuhan personal dan kualitas terbaik
          untuk momen spesial Anda.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/kontak" class="btn-primary">
            Konsultasi Sekarang
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a href="/portofolio" class="btn-outline">
            Lihat Portofolio
          </a>
        </div>
        <div class="mt-8 flex items-center gap-6 text-sm text-ink-light">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            Hasil Berkualitas
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            Harga Bersahabat
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
            Konsultasi Gratis
          </span>
        </div>
      </div>

      <div class="hidden lg:block relative">
        <div class="relative z-10 rounded-xl overflow-hidden card-shadow border border-border">
          <img
            src="https://picsum.photos/seed/print-hero/600/450"
            alt="Cetak undangan dan foto berkualitas"
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-accent/5 rounded-xl -z-10"></div>
        <div class="absolute -top-4 -right-4 w-24 h-24 border-2 border-accent/10 rounded-xl -z-10"></div>
      </div>
    </div>
  </div>
</section>
