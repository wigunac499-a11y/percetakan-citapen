---
---

<section class="relative overflow-hidden border-b border-border">
  <div class="print-grid absolute inset-0 opacity-30"></div>
  <div class="container-custom relative py-24 md:py-36">
    <div class="max-w-3xl">
      <span class="inline-block font-mono text-xs uppercase tracking-[0.2em] text-accent mb-6">
        Percetakan Bandung Barat
      </span>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight text-balance">
        Cetak Undangan & Foto
        <span class="block text-accent mt-2">Kualitas Terbaik</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-accent max-w-2xl leading-relaxed text-pretty">
        Dari undangan pernikahan impian hingga cetak foto kenangan berharga —
        kami hadirkan hasil cetak dengan sentuhan personal dan kualitas terbaik
        untuk momen spesial Anda.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/kontak"
          class="inline-flex items-center gap-2 rounded-sm border border-accent bg-accent px-6 py-3 text-sm font-medium text-white no-underline transition-all hover:bg-accent-light"
        >
          Konsultasi Sekarang
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="/portofolio"
          class="inline-flex items-center gap-2 rounded-sm border border-border bg-paper px-6 py-3 text-sm font-medium text-ink no-underline transition-all hover:bg-paper-dark"
        >
          Lihat Portofolio
        </a>
      </div>
    </div>
  </div>
  <div class="absolute right-0 top-0 bottom-0 w-1/3 hidden lg:block overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-l from-accent/5 to-transparent"></div>
    <div class="absolute right-12 top-1/4 w-64 h-80 border border-border overflow-hidden">
      <img
        src="https://picsum.photos/seed/hero-undangan/500/600"
        alt="Cetak undangan pernikahan premium"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="absolute right-32 bottom-1/4 w-48 h-60 border border-border overflow-hidden">
      <img
        src="https://picsum.photos/seed/hero-foto/400/500"
        alt="Cetak foto berkualitas tinggi"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>
