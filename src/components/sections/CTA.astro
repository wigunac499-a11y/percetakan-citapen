<section class="section-padding">
  <div class="container-custom">
    <div data-anim="anim-scale-in" class="relative overflow-hidden rounded-2xl bg-accent px-8 py-14 md:px-16 md:py-20 text-center">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
      <div class="relative max-w-2xl mx-auto">
        <span class="inline-block text-xs font-semibold uppercase tracking-wider text-white/80 mb-3 px-3 py-1 bg-white/10 rounded-full">
          Mulai Pesan
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-white text-balance">
          Siap Mewujudkan Cetakan Impian Anda?
        </h2>
        <p class="mt-4 text-white/80 text-base md:text-lg leading-relaxed">
          Konsultasi gratis dengan tim kami. Diskusikan desain, bahan, dan
          kebutuhan cetak Anda — tanpa commitmen.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a
            href="/kontak"
            class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-accent no-underline transition-all hover:bg-white/90"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
            </svg>
            Konsultasi via WhatsApp
          </a>
          <a
            href="/harga"
            class="inline-flex items-center gap-2 rounded-lg border border-white/30 px-6 py-3 text-sm font-semibold text-white no-underline transition-all hover:bg-white/10"
          >
            Lihat Estimasi Harga
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
