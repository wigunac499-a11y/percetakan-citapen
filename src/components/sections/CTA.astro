---

<section class="section-padding">
  <div class="container-custom">
    <div class="relative overflow-hidden rounded-sm border border-border bg-paper-dark p-10 md:p-16">
      <div class="print-grid absolute inset-0 opacity-20"></div>
      <div class="relative max-w-2xl mx-auto text-center">
        <span class="inline-block font-mono text-xs uppercase tracking-[0.2em] text-accent mb-4">
          Mulai Pesan
        </span>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-balance">
          Siap Mewujudkan Cetakan Impian Anda?
        </h2>
        <p class="mt-4 text-accent text-base md:text-lg leading-relaxed">
          Konsultasi gratis dengan tim kami. Diskusikan desain, bahan, dan
          kebutuhan cetak Anda — tanpa commitmen.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/kontak"
            class="inline-flex items-center gap-2 rounded-sm border border-accent bg-accent px-6 py-3 text-sm font-medium text-white no-underline transition-all hover:bg-accent-light"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
            </svg>
            Konsultasi via WhatsApp
          </a>
          <a
            href="/harga"
            class="inline-flex items-center gap-2 rounded-sm border border-border bg-paper px-6 py-3 text-sm font-medium text-ink no-underline transition-all hover:bg-paper-dark"
          >
            Lihat Estimasi Harga
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
