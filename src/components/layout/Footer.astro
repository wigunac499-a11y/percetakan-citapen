---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-paper-dark">
  <div class="container-custom py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <a href="/" class="text-lg font-bold text-ink no-underline">
          Citapen Printing
        </a>
        <p class="mt-4 text-sm text-ink-light leading-relaxed">
          Percetakan undangan dan foto di Bandung Barat. Hasil cetak berkualitas dengan sentuhan personal untuk momen spesial Anda.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink mb-4">Layanan</h4>
        <ul class="space-y-2.5">
          <li><a href="/layanan/cetak-undangan" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Cetak Undangan</a></li>
          <li><a href="/layanan/cetak-foto" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Cetak Foto</a></li>
          <li><a href="/portofolio" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Portofolio</a></li>
          <li><a href="/harga" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Estimasi Harga</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink mb-4">Informasi</h4>
        <ul class="space-y-2.5">
          <li><a href="/tentang" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Tentang Kami</a></li>
          <li><a href="/blog" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Blog</a></li>
          <li><a href="/testimoni" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Testimoni</a></li>
          <li><a href="/kontak" class="text-sm text-ink-light no-underline hover:text-accent transition-colors">Kontak</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink mb-4">Kontak</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-sm text-ink-light">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
            </svg>
            <span>Bandung Barat, Jawa Barat</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-ink-light">
            <svg class="h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
            </svg>
            <span>+62 812-3456-7890</span>
          </li>
          <li class="flex items-center gap-2 text-sm text-ink-light">
            <svg class="h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" />
            </svg>
            <span>info@citapenprinting.com</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ink-light">
      <p>&copy; {currentYear} Citapen Printing. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="#" class="hover:text-accent transition-colors no-underline">Instagram</a>
        <a href="#" class="hover:text-accent transition-colors no-underline">WhatsApp</a>
        <a href="#" class="hover:text-accent transition-colors no-underline">Facebook</a>
      </div>
    </div>
  </div>
</footer>
