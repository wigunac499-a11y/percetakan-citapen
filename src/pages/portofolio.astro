---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { breadcrumbSchema } from '../lib/schema';

const breadcrumbs = [
  { name: 'Beranda', url: 'https://percetakan.citapen.com/' },
  { name: 'Portofolio', url: 'https://percetakan.citapen.com/portofolio' },
];

const categories = ['Semua', 'Undangan', 'Cetak Foto', 'Banner'];
const items = [
  { id: 1, title: 'Undangan Pernikahan Rina & Andi', category: 'Undangan', seed: 'undangan-1' },
  { id: 2, title: 'Undangan Akad Sarah & Dika', category: 'Undangan', seed: 'undangan-2' },
  { id: 3, title: 'Undangan Tunangan Maya', category: 'Undangan', seed: 'undangan-3' },
  { id: 4, title: 'Album Foto Keluarga', category: 'Cetak Foto', seed: 'foto-1' },
  { id: 5, title: 'Cetak Kanvas Pemandangan', category: 'Cetak Foto', seed: 'foto-2' },
  { id: 6, title: 'Bingkai Foto Wisuda', category: 'Cetak Foto', seed: 'foto-3' },
  { id: 7, title: 'Banner Grand Opening', category: 'Banner', seed: 'banner-1' },
  { id: 8, title: 'X-Banner Promosi', category: 'Banner', seed: 'banner-2' },
  { id: 9, title: 'Spanduk Acara', category: 'Banner', seed: 'banner-3' },
];
---

<BaseLayout
  title="Portofolio Percetakan"
  description="Lihat hasil karya cetak undangan dan foto terbaru dari Citapen Printing. Galeri portofolio lengkap dengan berbagai kategori."
  breadcrumbs={breadcrumbs}
  jsonLd={[breadcrumbSchema(breadcrumbs)]}
>
  <div class="print-grid absolute inset-0 opacity-20 pointer-events-none" />

  <section class="section-padding">
    <div class="container-custom">
      <SectionHeading
        tag="Portofolio"
        title="Hasil Karya <em>Kami</em>"
        description="Setiap proyek adalah kebanggaan. Lihat langsung hasil cetakan yang sudah kami kerjakan untuk berbagai kebutuhan."
      />

      <div class="mt-12 flex flex-wrap justify-center gap-2" id="filter-buttons">
        {categories.map((cat) => (
          <button
            key={cat}
            data-filter={cat}
            class={cat === 'Semua'
              ? 'rounded-sm border border-accent bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-light'
              : 'rounded-sm border border-border bg-paper px-4 py-2 text-sm font-medium text-accent transition-colors hover:bg-paper-dark hover:text-ink'
            }
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="portfolio-grid">
        {items.map((item) => (
          <div
            key={item.id}
            class="portfolio-item group relative aspect-[3/4] overflow-hidden border border-border bg-paper-dark"
            data-category={item.category}
          >
            <img
              src={`https://picsum.photos/seed/${item.seed}/600/800`}
              alt={item.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-5">
                <span class="text-xs font-mono uppercase tracking-wider text-white/70">{item.category}</span>
                <h3 class="text-lg font-serif font-semibold text-white mt-1">{item.title}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll('#filter-buttons button');
  const portfolioItems = document.querySelectorAll('.portfolio-item');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterButtons.forEach((b) => {
        b.className = 'rounded-sm border border-border bg-paper px-4 py-2 text-sm font-medium text-accent transition-colors hover:bg-paper-dark hover:text-ink';
      });
      btn.className = 'rounded-sm border border-accent bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-light';

      const filter = btn.dataset.filter;
      portfolioItems.forEach((item) => {
        if (filter === 'Semua' || item.dataset.category === filter) {
          item.style.display = 'block';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
